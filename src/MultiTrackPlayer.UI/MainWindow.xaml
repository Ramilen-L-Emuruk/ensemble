<Window x:Class="MultiTrackPlayer.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:MultiTrackPlayer.UI.Controls"
        xmlns:local="clr-namespace:MultiTrackPlayer.UI"
        Title="{Binding Title}" Width="960" Height="600"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:NullToVisibilityConverter x:Key="NullToVis"/>
        <local:EmptyStringToVisibilityConverter x:Key="EmptyStringToVis"/>
    </Window.Resources>
    <DockPanel>
        <!-- Menu -->
        <Menu x:Name="AppMenu" DockPanel.Dock="Top">
            <MenuItem Header="ファイル(_F)">
                <MenuItem Header="開く(_O)" InputGestureText="Ctrl+O" Click="MenuOpen_Click"/>
                <Separator/>
                <MenuItem Header="終了(_X)" Click="MenuExit_Click"/>
            </MenuItem>
            <MenuItem Header="表示(_V)">
                <MenuItem Header="ミキサー(_M)" InputGestureText="Ctrl+M" Click="MenuMixer_Click"/>
                <MenuItem Header="プレイリスト(_L)" InputGestureText="Ctrl+L" Click="MenuPlaylist_Click"/>
                <MenuItem Header="チャプター(_T)" InputGestureText="Ctrl+T" Click="MenuChapter_Click"/>
                <Separator/>
                <MenuItem Header="フルスクリーン(_F)" InputGestureText="F11" Click="MenuFullscreen_Click"/>
            </MenuItem>
            <MenuItem Header="設定(_S)">
                <MenuItem Header="デバッグモード(_D)" IsCheckable="True"
                          IsChecked="{Binding IsDebugMode, Mode=TwoWay}"/>
                <Separator/>
                <MenuItem Header="現在のミュート状態を既定にする(_M)" Click="MenuSaveDefaultMutes_Click"
                          ToolTip="次回以降ファイルを開いたとき、いまミュートしているトラック番号を最初からミュートで開きます"/>
            </MenuItem>
            <MenuItem Header="再生(_P)">
                <MenuItem Header="再生/一時停止" InputGestureText="Space" Click="MenuPlayPause_Click"/>
                <MenuItem Header="停止" InputGestureText="S" Click="MenuStop_Click"/>
                <Separator/>
                <MenuItem Header="コマ送り" InputGestureText="." Click="MenuStepFwd_Click"/>
                <MenuItem Header="コマ戻し" InputGestureText="," Click="MenuStepBwd_Click"/>
                <Separator/>
                <MenuItem Header="速度">
                    <MenuItem Header="0.25x" Click="Speed_Click" Tag="0.25"/>
                    <MenuItem Header="0.50x" Click="Speed_Click" Tag="0.5"/>
                    <MenuItem Header="0.75x" Click="Speed_Click" Tag="0.75"/>
                    <MenuItem Header="1.00x" Click="Speed_Click" Tag="1.0"/>
                    <MenuItem Header="1.25x" Click="Speed_Click" Tag="1.25"/>
                    <MenuItem Header="1.50x" Click="Speed_Click" Tag="1.5"/>
                    <MenuItem Header="2.00x" Click="Speed_Click" Tag="2.0"/>
                </MenuItem>
            </MenuItem>
        </Menu>

        <!-- Status bar (drop-rate / video lag) — デバッグモード時のみ表示（フルスクリーン中は非表示） -->
        <TextBlock x:Name="StatusBar" DockPanel.Dock="Bottom" Background="#FF1A1A1A" Foreground="Gray"
                   FontFamily="Consolas" FontSize="10" Padding="8,2"
                   Text="{Binding StatusText}"
                   Visibility="{Binding IsDebugMode, Converter={StaticResource BoolToVis}}"/>

        <!-- Transport bar bottom -->
        <StackPanel x:Name="TransportBar" DockPanel.Dock="Bottom" Background="#FF1E1E1E">
            <!-- SeekBar -->
            <ctrl:SeekBarControl x:Name="SeekBar" Margin="8,6,8,2"
                                 PositionRatio="{Binding PositionRatio, Mode=TwoWay}"
                                 Duration="{Binding Duration}"/>
            <!-- Time labels + transport buttons -->
            <Grid Margin="8,0,8,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Foreground="White" FontFamily="Consolas" FontSize="12"
                           Text="{Binding Position, StringFormat={}{0:hh\\:mm\\:ss}}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="⏮" Click="PrevFile_Click" Style="{StaticResource TransportBtn}"/>
                    <Button Content="⏪" Click="SkipBack_Click" Style="{StaticResource TransportBtn}"/>
                    <Button Content="⏸" Click="PlayPause_Click" Style="{StaticResource TransportBtn}" Width="44"/>
                    <Button Content="⏩" Click="SkipFwd_Click" Style="{StaticResource TransportBtn}"/>
                    <Button Content="⏭" Click="NextFile_Click" Style="{StaticResource TransportBtn}"/>
                    <ComboBox x:Name="SpeedBox" Width="60" Margin="8,0,0,0" VerticalAlignment="Center"
                              SelectionChanged="SpeedBox_SelectionChanged">
                        <ComboBoxItem Tag="0.25">0.25x</ComboBoxItem>
                        <ComboBoxItem Tag="0.5">0.5x</ComboBoxItem>
                        <ComboBoxItem Tag="0.75">0.75x</ComboBoxItem>
                        <ComboBoxItem Tag="1.0" IsSelected="True">1.0x</ComboBoxItem>
                        <ComboBoxItem Tag="1.25">1.25x</ComboBoxItem>
                        <ComboBoxItem Tag="1.5">1.5x</ComboBoxItem>
                        <ComboBoxItem Tag="2.0">2.0x</ComboBoxItem>
                    </ComboBox>
                </StackPanel>
                <TextBlock Grid.Column="2" Foreground="White" FontFamily="Consolas" FontSize="12"
                           Text="{Binding Duration, StringFormat={}{0:hh\\:mm\\:ss}}" VerticalAlignment="Center"/>
            </Grid>
        </StackPanel>

        <!-- Video area -->
        <Grid Background="Black">
            <Image x:Name="VideoImage" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
            <TextBlock x:Name="DropHint" Text="ファイルをドロップして開く"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="Gray" FontSize="18"
                       Visibility="{Binding CurrentMedia, Converter={StaticResource NullToVis}}"/>

            <!-- 操作 OSD: 何か操作を行うたび一瞬だけ内容を表示する（無操作で自動的に消える） -->
            <Border HorizontalAlignment="Left" VerticalAlignment="Top" Margin="16,16,0,0"
                    Background="#B0000000" CornerRadius="4" Padding="14,6" IsHitTestVisible="False"
                    Visibility="{Binding OsdText, Converter={StaticResource EmptyStringToVis}}">
                <TextBlock Text="{Binding OsdText}" Foreground="White" FontSize="16"/>
            </Border>

            <!-- フルスクリーン時のオーバーレイ: マウス移動・キー操作で一時表示し、無操作で自動的に消える -->
            <Border x:Name="FullscreenOverlay" VerticalAlignment="Bottom"
                    Background="#CC000000" Padding="8,6" Visibility="Collapsed">
                <StackPanel>
                    <ctrl:SeekBarControl x:Name="FullscreenSeekBar" Margin="0,0,0,4"
                                         PositionRatio="{Binding PositionRatio, Mode=TwoWay}"
                                         Duration="{Binding Duration}"/>
                    <TextBlock Foreground="White" FontFamily="Consolas" FontSize="12" HorizontalAlignment="Center">
                        <Run Text="{Binding Position, StringFormat={}{0:hh\\:mm\\:ss}}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding Duration, StringFormat={}{0:hh\\:mm\\:ss}}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>