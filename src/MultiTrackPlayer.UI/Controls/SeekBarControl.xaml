<UserControl x:Class="MultiTrackPlayer.UI.Controls.SeekBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="24">
    <Grid>
        <Popup x:Name="ThumbnailPopup" Placement="Relative" PlacementTarget="{Binding ElementName=TrackCanvas}"
               AllowsTransparency="True" IsHitTestVisible="False" IsOpen="False">
            <Border Background="#EE202020" BorderBrush="#FF606060" BorderThickness="1" Padding="2">
                <StackPanel>
                    <Image x:Name="ThumbnailImage" Stretch="None" SnapsToDevicePixels="True"/>
                    <TextBlock x:Name="ThumbnailTimeText" Foreground="White" FontSize="11"
                               HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Popup>
        <Canvas x:Name="TrackCanvas" Background="#FF404040"
                MouseLeftButtonDown="Canvas_MouseLeftButtonDown"
                MouseMove="Canvas_MouseMove"
                MouseLeftButtonUp="Canvas_MouseLeftButtonUp"
                MouseEnter="Canvas_MouseEnter"
                MouseLeave="Canvas_MouseLeave"
                Cursor="Hand">
            <Rectangle x:Name="ProgressRect" Height="4" Fill="#FF2196F3"
                       Canvas.Left="0" Canvas.Top="10"/>
            <ItemsControl x:Name="ChapterMarkers" Canvas.Left="0" Canvas.Top="0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left" Value="{Binding X}"/>
                    </Style>
                </ItemsControl.ItemContainerStyle>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Rectangle Width="2" Height="24" Fill="White" Opacity="0.7"
                                   ToolTip="{Binding ToolTip}"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            <Ellipse x:Name="Thumb" Width="12" Height="12"
                     Fill="White" Canvas.Top="4"
                     IsHitTestVisible="False"/>
        </Canvas>
    </Grid>
</UserControl>