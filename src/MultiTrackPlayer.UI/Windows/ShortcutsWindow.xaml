<Window x:Class="MultiTrackPlayer.UI.Windows.ShortcutsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ショートカットキー一覧" Width="360" Height="520"
        WindowStyle="ToolWindow" ShowInTaskbar="False">
    <Grid>
        <ListBox x:Name="ShortcutList" BorderThickness="0">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Key}" FontFamily="Consolas" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="{Binding Action}" Margin="8,0,0,0" TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>
