<Window x:Class="MultiTrackPlayer.UI.Windows.ChapterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="チャプター" Width="380" Height="400"
        WindowStyle="ToolWindow" ShowInTaskbar="False">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ListBox x:Name="ChapterList" Grid.Row="0"
                 ItemsSource="{Binding Chapters}"
                 MouseDoubleClick="ChapterList_MouseDoubleClick"
                 PreviewKeyDown="ChapterList_PreviewKeyDown">
            <ListBox.ItemContainerStyle>
                <!--
                    既定の ListBoxItem テーマスタイルは選択時に背景を独自に塗り替えてしまい、
                    Style.Triggers で設定した IsCurrent の背景色が選択中は隠れてしまう。
                    そのため Background は IsCurrent 専任、選択状態は枠線で表現するよう分離する。
                -->
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="2"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bd" Background="Transparent"
                                        BorderThickness="1" BorderBrush="Transparent"
                                        Padding="{TemplateBinding Padding}"
                                        SnapsToDevicePixels="True">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#FF2D4A63"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="#FF3A3A3A"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#FF64B5F6"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="60"/>
                        </Grid.ColumnDefinitions>

                        <!-- 自動検出(グレー)/ユーザー追加(オレンジ)を色で区別 -->
                        <Rectangle Grid.Column="0" Width="4" Margin="0,1">
                            <Rectangle.Style>
                                <Style TargetType="Rectangle">
                                    <Setter Property="Fill" Value="#FF808080"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUserDefined}" Value="True">
                                            <Setter Property="Fill" Value="#FFFF9800"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Rectangle.Style>
                        </Rectangle>

                        <TextBlock Grid.Column="1" Text="{Binding TimeLabel}" FontFamily="Consolas" Margin="4,0"/>

                        <Grid Grid.Column="2" Margin="4,0">
                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis"
                                       MouseLeftButtonDown="Title_MouseLeftButtonDown">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBox Text="{Binding Title, Mode=OneWay}"
                                     KeyDown="TitleEditBox_KeyDown"
                                     LostFocus="TitleEditBox_LostFocus"
                                     IsVisibleChanged="TitleEditBox_IsVisibleChanged">
                                <TextBox.Style>
                                    <Style TargetType="TextBox">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <Button Grid.Column="3" Content="削除" FontSize="10" Padding="4,2"
                                Visibility="{Binding IsUserDefined, Converter={StaticResource BoolToVis}}"
                                Click="Delete_Click" Tag="{Binding}"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Button Grid.Row="1" Content="＋ 現在位置にチャプター追加" Click="Add_Click"
                Margin="8" Padding="8,6"/>
    </Grid>
</Window>
