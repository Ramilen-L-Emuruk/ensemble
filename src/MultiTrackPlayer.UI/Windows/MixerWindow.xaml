<Window x:Class="MultiTrackPlayer.UI.Windows.MixerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ミキサー" Width="320" SizeToContent="Height"
        WindowStyle="ToolWindow" ShowInTaskbar="False">
    <StackPanel Margin="8">
        <TextBlock Text="オーディオトラック" FontWeight="Bold" Margin="0,0,0,8"/>
        <ItemsControl ItemsSource="{Binding AudioTracks}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding Name}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                        <Slider Grid.Column="1" Minimum="0" Maximum="200" Value="{Binding Volume}"
                                VerticalAlignment="Center" Margin="4,0"/>
                        <TextBlock Grid.Column="2" Text="{Binding Volume, StringFormat={}{0:0}%}"
                                   VerticalAlignment="Center" TextAlignment="Right"/>
                        <ToggleButton Grid.Column="3" Content="MUTE" IsChecked="{Binding IsMuted}"
                                      Margin="4,0" FontSize="9" Padding="2"/>
                    </Grid>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
        <Separator Margin="0,8"/>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="マスター音量" VerticalAlignment="Center"/>
            <Slider Grid.Column="1" Minimum="0" Maximum="100" Value="{Binding MasterVolume}"
                    VerticalAlignment="Center" Margin="4,0"/>
            <TextBlock Grid.Column="2" Text="{Binding MasterVolume, StringFormat={}{0:0}%}"
                       VerticalAlignment="Center" TextAlignment="Right"/>
        </Grid>
    </StackPanel>
</Window>