<Window x:Class="MultiTrackPlayer.UI.Windows.DebugWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="デバッグ情報" Width="440" SizeToContent="Height"
        WindowStyle="ToolWindow" ShowInTaskbar="False"
        FontFamily="Consolas" FontSize="11">
    <StackPanel Margin="10">
        <TextBlock Text="再生統計" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap"/>
        <TextBlock Margin="0,4,0,0">
            <Run Text="状態: "/><Run Text="{Binding PlaybackState, Mode=OneWay}"/>
            <Run Text="   速度: "/><Run Text="{Binding PlaybackSpeed, Mode=OneWay, StringFormat={}{0:0.00}x}"/>
        </TextBlock>
        <TextBlock Margin="0,2,0,0">
            <Run Text="位置: "/><Run Text="{Binding Position, Mode=OneWay, StringFormat={}{0:hh\\:mm\\:ss\\.fff}}"/>
            <Run Text=" / "/><Run Text="{Binding Duration, Mode=OneWay, StringFormat={}{0:hh\\:mm\\:ss}}"/>
        </TextBlock>

        <Separator Margin="0,10"/>
        <TextBlock Text="ファイル情報" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock Text="{Binding CurrentMedia.FilePath, StringFormat=パス: {0}}" TextWrapping="Wrap"/>
        <TextBlock Margin="0,2,0,0">
            <Run Text="解像度: "/><Run Text="{Binding CurrentMedia.Width, Mode=OneWay}"/>
            <Run Text=" x "/><Run Text="{Binding CurrentMedia.Height, Mode=OneWay}"/>
            <Run Text="   HDR: "/><Run Text="{Binding CurrentMedia.HasHdr, Mode=OneWay}"/>
        </TextBlock>
        <TextBlock Margin="0,2,0,0">
            <Run Text="総時間: "/><Run Text="{Binding CurrentMedia.Duration, Mode=OneWay, StringFormat={}{0:hh\\:mm\\:ss}}"/>
            <Run Text="   映像ストリームIndex: "/><Run Text="{Binding CurrentMedia.VideoStreamIndex, Mode=OneWay}"/>
        </TextBlock>

        <Separator Margin="0,10"/>
        <TextBlock Text="音声トラック" FontWeight="Bold" Margin="0,0,0,4"/>
        <ItemsControl ItemsSource="{Binding CurrentMedia.AudioTracks}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <TextBlock Margin="0,1" TextWrapping="Wrap">
                        <Run Text="{Binding TrackNumber, Mode=OneWay, StringFormat=#{0}}"/>
                        <Run Text=" "/><Run Text="{Binding Name, Mode=OneWay}"/>
                        <Run Text=" ["/><Run Text="{Binding Language, Mode=OneWay}"/><Run Text="]"/>
                        <Run Text="  "/><Run Text="{Binding CodecName, Mode=OneWay}"/>
                        <Run Text="  "/><Run Text="{Binding Channels, Mode=OneWay}"/><Run Text="ch"/>
                        <Run Text="  "/><Run Text="{Binding SampleRate, Mode=OneWay}"/><Run Text="Hz"/>
                    </TextBlock>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </StackPanel>
</Window>
