<Window x:Class="MultiTrackPlayer.UI.Windows.PlaylistWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="プレイリスト" Width="400" Height="400"
        WindowStyle="ToolWindow" ShowInTaskbar="False"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <ListBox x:Name="FileList" Grid.Row="0"
                 ItemsSource="{Binding Playlist.Files}"
                 SelectedIndex="{Binding Playlist.CurrentIndex}"
                 MouseDoubleClick="FileList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"
                               ToolTip="{Binding}"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="4">
            <Button Content="追加" Click="Add_Click" Padding="8,4" Margin="2"/>
            <Button Content="削除" Click="Remove_Click" Padding="8,4" Margin="2"/>
            <Button Content="クリア" Click="Clear_Click" Padding="8,4" Margin="2"/>
        </StackPanel>
    </Grid>
</Window>